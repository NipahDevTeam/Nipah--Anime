# Nipah! Anime — OAuth Credentials
# Copy this file to .env.local and fill in your own values.
# These are injected at build time via ldflags — see README for build instructions.
#
# Register your own OAuth apps at:
#   AniList:       https://anilist.co/settings/developer
#
# Without these, the app builds and runs normally — AniList/MAL sync will be disabled.

ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=
